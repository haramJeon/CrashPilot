{
  "name": "crashpilot-server",
  "version": "1.0.0",
  "private": true,
  "bin": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pkg": "npx @yao-pkg/pkg . --compress GZip --out-path ../release"
  },
  "pkg": {
    "scripts": ["dist/**/*.js"],
    "assets": [
      "node_modules/mysql2/**/*",
      "node_modules/iconv-lite/**/*",
      "node_modules/chardet/**/*"
    ],
    "targets": [
      "node20-win-x64",
      "node20-mac-x64",
      "node20-mac-arm64"
    ],
    "outputPath": "../release"
  },
  "dependencies": {
    "@azure/msal-node": "^2.6.4",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@octokit/rest": "^20.0.2",
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "isomorphic-fetch": "^3.0.0",
    "mysql2": "^3.20.0",
    "simple-git": "^3.22.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/uuid": "^9.0.8",
    "@yao-pkg/pkg": "^5.12.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
