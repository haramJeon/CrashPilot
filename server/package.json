{
  "name": "crashpilot-server",
  "version": "0.9.0.8",
  "private": true,
  "bin": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --ignore ../config.json src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pkg": "npx @yao-pkg/pkg . --out-path ../release"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [],
    "targets": [
      "node20-win-x64",
      "node20-mac-x64",
      "node20-mac-arm64"
    ],
    "outputPath": "../release"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "isomorphic-fetch": "^3.0.0",
    "simple-git": "^3.22.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.0",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/uuid": "^9.0.8",
    "@types/yauzl": "^2.10.3",
    "@yao-pkg/pkg": "^5.12.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
